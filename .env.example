# ===========================================
# PraktiQU Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/praktiqu"

# ===========================================
# NEXTAUTH.JS AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Application URL (for production, change to your domain)
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Public URL for the application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Application Name
NEXT_PUBLIC_APP_NAME="PraktiQU"

# Default timezone for new clinics
DEFAULT_TIMEZONE="UTC"

# ===========================================
# OPTIONAL: Email Configuration
# ===========================================
# Email provider for notifications (SMTP)
# EMAIL_HOST="smtp.example.com"
# EMAIL_PORT="587"
# EMAIL_USER="your-email@example.com"
# EMAIL_PASSWORD="your-email-password"
# EMAIL_FROM="noreply@praktiqu.com"

# ===========================================
# OPTIONAL: Payment Gateways
# ===========================================
# PayPal Configuration
# PAYPAL_CLIENT_ID="your-paypal-client-id"
# PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
# PAYPAL_MODE="sandbox" # or "live"

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Enable debug mode (development only)
NODE_ENV="development"

# Enable verbose logging
DEBUG="false"