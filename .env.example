# ===========================================
# PraktiQU Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in the values.
# Reference: .specify/memory/constitution.md (PraktiQU v2.0.0)
# Stack: Next.js 14+ (App Router) + TypeScript + MySQL + Prisma + NextAuth v5

# ===========================================
# APPLICATION DATABASE (Prisma)
# ===========================================
# Primary database for PraktiQU. MySQL is required by the constitution
# (existing WordPress DB compatibility).
DATABASE_URL="mysql://praktiqu:praktiqu@localhost:3306/praktiqu"

# Optional: Prisma connection pool / shadow DB
# DATABASE_POOL_SIZE="10"
# SHADOW_DATABASE_URL="mysql://praktiqu:praktiqu@localhost:3306/praktiqu_shadow"

# ===========================================
# WORDPRESS INTEGRATION (Sibling service on shared MySQL)
# ===========================================
# Architecture:
#   - One MySQL instance, two schemas: `praktiqu` (Prisma) and `wordpress` (WP).
#   - PraktiQU does NOT write to `wp_*` tables. WordPress does NOT write to PraktiQU tables.
#   - PraktiQU reads `wp_users` / `wp_usermeta` to look up identity and roles
#     (WordPress remains the source of truth for credentials and password hashes).
#   - Authentication is performed via a custom WordPress REST endpoint registered
#     by a PraktiQU WordPress plugin (see `001-auth-foundation/spec.md`).
#
# WORDPRESS_AUTH_SYNC enables the cross-schema read path:
#   - true  → PraktiQU reads identity from `wp_users` on every login (recommended).
#   - false → PraktiQU uses only its own `users` table (no WP coupling; loses identity sync).
WORDPRESS_DATABASE_URL="mysql://praktiqu:praktiqu@localhost:3306/wordpress"
WORDPRESS_TABLE_PREFIX="wp_"
WORDPRESS_URL="http://localhost:9001"
WORDPRESS_AUTH_SYNC="true"

# Service-to-service auth header for the custom WP REST endpoint
# (rotate via deployment; never commit real values).
WORDPRESS_SERVICE_TOKEN="dev-service-token-change-me"

# ===========================================
# NEXTAUTH.JS v5 AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Public application URL (used for callbacks, emails, and absolute links)
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"  # v4-compat alias

# Required for Vercel / reverse-proxy deployments so NextAuth trusts forwarded host headers
AUTH_TRUST_HOST="true"

# JWT session lifetime (seconds). Default 30 days.
# AUTH_SESSION_MAX_AGE="2592000"

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PraktiQU"

# Default timezone for new clinics (IANA, e.g. Asia/Jakarta)
DEFAULT_TIMEZONE="Asia/Jakarta"

# Pagination defaults (constitution: default 20, max 100)
DEFAULT_PAGE_SIZE="20"
MAX_PAGE_SIZE="100"

# Rate limiting (constitution: 100 req/min per user, global)
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# ===========================================
# LOGGING & MONITORING
# ===========================================
# Log level: ERROR | WARN | INFO | DEBUG | TRACE
LOG_LEVEL="INFO"

# Retention (days) per constitution
LOG_RETENTION_DEBUG_DAYS="7"
LOG_RETENTION_INFO_DAYS="30"
LOG_RETENTION_AUDIT_DAYS="90"
LOG_RETENTION_PERF_DAYS="7"

# Health check exposed at GET /api/health (no env var required)

# ===========================================
# EMAIL — SMTP transport (C7 decision)
# ===========================================
# Development: MailHog (via docker-compose `mail` service) catches all mail
# Production: cPanel-provided SMTP server (shared hosting)
# Transport: nodemailer with SMTP

# Sender (the "from" address on outbound mail)
EMAIL_FROM="noreply@praktiqu.local"

# Dev defaults (MailHog)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
# SMTP_USER and SMTP_PASSWORD left blank in dev (MailHog accepts anything)

# Production: fill in the cPanel SMTP credentials below
# SMTP_HOST="mail.yourdomain.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="noreply@yourdomain.com"
# SMTP_PASSWORD="cpanel-email-account-password"

# ===========================================
# OPTIONAL: Payment Gateways
# ===========================================
# PayPal
# PAYPAL_CLIENT_ID="your-paypal-client-id"
# PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
# PAYPAL_MODE="sandbox" # or "live"

# Stripe (Billing feature, 011)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Payment webhook signature secret (Xendit via WooCommerce, 2026-07 payment feature).
# MUST differ from AUTH_SECRET / WORDPRESS_WEBHOOK_SECRET — configured
# independently in the praktiqu-endpoint plugin's "Payment Webhook Secret"
# setting (Settings → PraktiQU Endpoint). Generate with: openssl rand -base64 32
PAYMENT_WEBHOOK_SECRET="dev-payment-webhook-secret-change-me"

# ===========================================
# OPTIONAL: Object Storage (Uploads)
# ===========================================
# S3-compatible (used by Session Notes attachments, profile photos)
# S3_ENDPOINT="https://s3.example.com"
# S3_REGION="ap-southeast-1"
# S3_BUCKET="praktiqu-uploads"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
NODE_ENV="development"
DEBUG="false"

# Verbose Prisma query logs (set "true" to log all SQL)
# PRISMA_LOG_QUERIES="false"
