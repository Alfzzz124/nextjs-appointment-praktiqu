# ===========================================
# PraktiQU Environment Configuration
# ===========================================

# ===========================================
# APPLICATION DATABASE (Prisma - MySQL in Docker)
# ===========================================
DATABASE_URL="mysql://root:root@localhost:3306/wordpress-praktiqu"

# ===========================================
# WORDPRESS INTEGRATION (Sibling service on shared MySQL)
# ===========================================
WORDPRESS_DATABASE_URL="mysql://root:root@localhost:3306/wordpress-praktiqu"
WORDPRESS_TABLE_PREFIX="wp_"
WORDPRESS_URL="http://localhost:9001"
WORDPRESS_AUTH_SYNC="false"

# Service-to-service auth header for the custom WP REST endpoint
WORDPRESS_SERVICE_TOKEN="dev-service-token-change-me"

# ===========================================
# NEXTAUTH.JS v5 AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="dev-secret-change-in-production-12345678901234567890"

# Public application URL
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PraktiQU"
DEFAULT_TIMEZONE="Asia/Jakarta"
DEFAULT_PAGE_SIZE="20"
MAX_PAGE_SIZE="100"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# ===========================================
# LOGGING & MONITORING
# ===========================================
LOG_LEVEL="INFO"

# ===========================================
# EMAIL — Development (MailHog placeholder)
# ===========================================
EMAIL_FROM="noreply@praktiqu.local"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
NODE_ENV="development"
DEBUG="false"