// ============================================
// LOGGING — user activity + errors
// ============================================
// Source of truth: docs/architecture/logging.md
// Constitution §Logging & Monitoring mandates database-backed structured
// logging. This is the single table for all log records; the `level` and
// `category` fields determine retention (see logging.md).
//
// Conventions:
//   - ACTIVITY entries: every meaningful user action (login, booking, edit).
//   - ERROR entries: unhandled exceptions, 5xx responses, integration failures.
//   - SYSTEM entries: background jobs, cron, scheduled tasks.
//   - AUTH events (login success/failure, password change) ALSO go here with
//     category=ACTIVITY and level=INFO/WARN. The auth-foundation spec's
//     AuditLog is a query view over this table filtered by action prefix.
//
// Access: SUPER_ADMIN read via GET /api/v1/admin/logs (paginated).
// Retention (per constitution):
//   DEBUG, TRACE  → 7 days
//   INFO, WARN    → 30 days
//   ERROR         → 30 days
//   AUDIT         → 90 days
//   PERF          → 7 days (aggregated; deferred)
// A scheduled job (C8) purges entries older than the retention window.

enum LogLevel {
  DEBUG
  TRACE
  INFO
  WARN
  ERROR
  AUDIT
  PERF
}

enum LogCategory {
  ACTIVITY // user-facing actions
  ERROR    // unhandled exceptions, integration failures
  SYSTEM   // background jobs, scheduled tasks, server lifecycle
}

model LogEntry {
  id         String      @id @default(cuid())
  level      LogLevel    @default(INFO)
  category   LogCategory @default(ACTIVITY)
  message    String      @db.Text
  userId     String?     // null for anonymous / system events
  action     String?     // dotted path: "user.login", "session.book", "client.create"
  resource   String?     // entity affected: "session", "client", "bill"
  resourceId String?
  ip         String?
  userAgent  String?     @db.Text
  requestId  String?     // correlate across handlers in one request
  path       String?     // request path (e.g. "/api/v1/sessions")
  method     String?     // HTTP method
  statusCode Int?        // response status (for API-request entries)
  errorStack String?     @db.Text // populated when an Error object is passed
  metadata   Json?       // free-form context (sanitized request body, before/after values, etc.)
  occurredAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([level, occurredAt])
  @@index([category, occurredAt])
  @@index([userId, occurredAt])
  @@index([action, occurredAt])
  @@index([requestId])
  @@index([occurredAt])
  @@map("log_entries")
}

// ============================================
// INTERVENTION PLAN (Feature 009)
// ============================================
// A professional creates an intervention plan after a session. The plan is
// linked to a single session (one plan per session) and contains one or more
// recommendation items (activities / exercises the client should follow).
//
// The plan is visible to:
//   - The Professional who created it
//   - The Client it belongs to
//   - Receptionist / Admin (read-only)
//
// Status lifecycle:
//   PlanStatus     ACTIVE → COMPLETED
//   ItemStatus     ACTIVE → COMPLETED  (set by the client, never by professional)
//
// FR-004: plan creation and item completion emit AUDIT log entries.
// FR-005: plan summary is exposed for feature 014 (progress tracking).

enum PlanStatus {
  ACTIVE
  COMPLETED
}

enum ItemStatus {
  ACTIVE
  COMPLETED
}

model InterventionPlan {
  id              String        @id @default(cuid())
  sessionId       String        @unique
  professionalId  String
  clientId        String
  status          PlanStatus    @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items RecommendationItem[]

  @@index([professionalId])
  @@index([clientId])
  @@index([status])
  @@map("intervention_plans")
}

model RecommendationItem {
  id                  String     @id @default(cuid())
  interventionPlanId  String
  description         String     @db.Text
  frequency           String?
  durationDays        Int?
  instructions        String?    @db.Text
  status              ItemStatus @default(ACTIVE)
  completedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  plan InterventionPlan @relation(fields: [interventionPlanId], references: [id], onDelete: Cascade)

  @@index([interventionPlanId])
  @@index([status])
  @@map("recommendation_items")
}

// ============================================
// SESSION NOTES (Feature 008)
// ============================================
// Source of truth: specs/008-session-notes/plan.md
// One note per session. Notes are locked when the session reaches
// COMPLETED or when the professional manually closes them.
// `summary` holds the first 200 characters of `content` for feature
// 014 (client progress tracking) to read without touching content.

enum NoteStatus {
  OPEN
  CLOSED
}

model SessionNote {
  id             String     @id @default(cuid())
  sessionId      String     @unique
  professionalId String
  summary        String     @db.VarChar(200)
  content        String     @db.Text
  status         NoteStatus @default(OPEN)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  closedAt       DateTime?

  @@index([professionalId])
  @@index([status])
  @@index([sessionId])
  @@map("session_notes")
}

// ============================================
// INFORMED CONSENT (Feature 010)
// ============================================
// Consent forms are clinic-scoped templates; signatures are per-form/per-client
// captures with timestamp + IP for evidentiary purposes (FR-02, FR-03).
//
// ConsentForm.status lifecycle:
//   DRAFT     → being authored (not yet sent)
//   SENT      → sent to client for signature (has at least one pending sig)
//   SIGNED    → client has signed (active consent on file)
//   WITHDRAWN → client or admin revoked consent after signing (FR-05)
//   ARCHIVED  → retired template; not used for new requests
//
// ConsentSignature.status:
//   PENDING  → signature request sent, awaiting client action
//   SIGNED   → client signed (signedAt + ipAddress + userAgent captured)
//   DECLINED → client explicitly declined
//   EXPIRED  → sentAt + 30d passed without action (enforced by background job)

enum ConsentFormStatus {
  DRAFT
  SENT
  SIGNED
  WITHDRAWN
  ARCHIVED
}

enum ConsentSignatureStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
}

model ConsentForm {
  id          String            @id @default(cuid())
  practiceId  String            // Clinic.id — multi-tenant scoping
  name        String            // Template display name (e.g. "Telehealth Consent")
  content     String            @db.LongText // Dynamic content (HTML/markdown body the client will see)
  status      ConsentFormStatus @default(DRAFT)
  version     Int               @default(1) // Bumped on each substantive edit
  createdById String            // User.id (CLINIC_ADMIN or PROFESSIONAL) who authored
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  signatures ConsentSignature[]

  @@index([practiceId, status])
  @@index([createdById])
  @@index([status])
  @@map("consent_forms")
}

model ConsentSignature {
  id            String                @id @default(cuid())
  formId        String
  clientId      String                // User.id (CLIENT) who is being asked to sign
  status        ConsentSignatureStatus @default(PENDING)
  signedAt      DateTime?
  ipAddress     String?               @db.VarChar(64) // IPv4 or IPv6 at signature time
  userAgent     String?               @db.VarChar(512)
  signatureSvg  String?               @db.LongText // SVG path data of the captured signature
  signatureText String?               // Typed name (alternative to drawn signature)
  declineReason String?               @db.Text
  sentAt        DateTime              @default(now())
  expiresAt     DateTime              // sentAt + 30d
  withdrawnAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  form   ConsentForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  client User        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([formId, clientId]) // One active signature request per (form, client)
  @@index([clientId, status])
  @@index([formId, status])
  @@index([status, expiresAt])
  @@map("consent_signatures")
}
// ============================================
// PROFESSIONAL MANAGEMENT (Feature 002)
// ============================================
// Professional is the canonical entity for psychologists/psychiatrists
// providing sessions. It links to a WordPress User (1:1) and to a single
// Practice (n:1) for v1.

enum ProfessionalType {
  PSIKOLOG_KLINIS
  PSIKOLOG_ANAK
  PSIKIATER
  KONSELOR
}

enum ProfessionalStatus {
  PENDING_ACTIVATION
  ACTIVE
  INACTIVE
}

model Professional {
  id                 String             @id @default(cuid())
  userId             String             @unique
  practiceId         String?
  fullName           String
  email              String             @unique
  professionalType   ProfessionalType
  registrationNumber String             @unique
  status             ProfessionalStatus @default(PENDING_ACTIVATION)
  biography          String?            @db.Text
  specialties        Json?
  contactInfo        Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user                User                          @relation("UserProfessional", fields: [userId], references: [id], onDelete: Cascade)
  practice            Clinic?                       @relation("ClinicProfessionals", fields: [practiceId], references: [id])
  availability        ProfessionalAvailability[]
  offDays             ProfessionalOffDay[]
  serviceAssignments  ProfessionalServiceAssignment[]

  @@index([practiceId, status])
  @@index([status])
  @@map("professionals")
}

model ProfessionalAvailability {
  id              String   @id @default(cuid())
  professionalId  String
  dayOfWeek       Int
  startMinute     Int
  endMinute       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek, startMinute])
  @@index([professionalId, dayOfWeek])
  @@map("professional_availability")
}

model ProfessionalOffDay {
  id              String   @id @default(cuid())
  professionalId  String
  startDate       DateTime @db.Date
  endDate         DateTime @db.Date
  reason          String?
  createdAt       DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, startDate, endDate])
  @@map("professional_off_days")
}

model ProfessionalServiceAssignment {
  id              String   @id @default(cuid())
  professionalId  String
  serviceId       String
  createdAt       DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@unique([professionalId, serviceId])
  @@index([professionalId])
  @@map("professional_service_assignments")
}
