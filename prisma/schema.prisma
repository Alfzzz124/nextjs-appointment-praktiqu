// ============================================================
// PraktiQU - Clinic Management System
// ============================================================
// Database Schema based on KiviCare WordPress Plugin
//
// This schema mirrors the KiviCare database structure
// for the Next.js recreation
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================
// PraktiQU and WordPress share a single MySQL instance (sibling model).
// WordPress is the SOLE source of truth for credentials. There is NO password
// column on the PraktiQU User — passwords live in wp_users.user_pass (PHPASS).
// PraktiQU verifies passwords by calling the praktiqu-auth WP plugin's REST
// endpoint: POST /wp-json/praktiqu/v1/authenticate
//
// Identity + credential staleness is addressed via signed webhooks emitted by
// the praktiqu-auth plugin (password.changed, user.deactivated, etc.).
// See: src/lib/auth/role-mapping.ts and docs/architecture/role-taxonomy.md.

enum UserRole {
  SUPER_ADMIN     // WP role: "administrator" (core WP)
  CLINIC_ADMIN    // WP role: "kiviCare_clinic_admin"
  PROFESSIONAL    // WP role: "kiviCare_doctor"
  RECEPTIONIST    // WP role: "kiviCare_receptionist"
  CLIENT          // WP role: "kiviCare_patient"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  firstName     String
  lastName      String
  displayName   String
  role          UserRole  @default(CLIENT)
  // NOTE: No password column — WP owns credentials. See block comment above.
  wpRole        String?   // raw WordPress role slug (e.g. "kiviCare_doctor"); null if provisioned outside WP
  wpUserId      BigInt?   @unique // WordPress user ID (wp_users.ID) for cross-system lookups
  status        Int       @default(1) // 0 = inactive, 1 = active
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  clinicAdmin   Clinic?               @relation("ClinicAdmin")
  doctor        Doctor?
  receptionist  Receptionist?
  patient       Patient?
  sessions      AuthSession[]
  logEntries    LogEntry[]

  // Role assignments
  doctorClinics       DoctorClinicMapping[]
  receptionistClinics ReceptionistClinicMapping[]
  patientClinics      PatientClinicMapping[]

  // Meta data
  basicData     Json?    // mobile_number, dob, gender, blood_group, address, etc.
  timezone      String?

  @@index([wpUserId])
  @@index([wpRole])
  @@map("users")
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================
// CLINIC MANAGEMENT
// ============================================

model Clinic {
  id                 String   @id @default(cuid())
  name               String
  email              String?
  telephoneNo        String?
  specialties        Json?    // Array of specialty IDs/names
  address            String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  countryCode        String?
  countryCallingCode String?
  status             Int      @default(0) // 0 = inactive, 1 = active
  clinicAdminId      String?  @unique
  clinicLogo         Int?
  profileImage       Int?
  extra              Json?    // currency settings, custom config
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  clinicAdmin      User?                      @relation("ClinicAdmin", fields: [clinicAdminId], references: [id])
  appointments    Appointment[]
  encounters       Encounter[]
  bills            Bill[]
  clinicSessions   ClinicSession[]
  clinicSchedules  ClinicSchedule[]
  holidays         Holiday[]
  services         Service[]
  doctors          DoctorClinicMapping[]
  receptionists    ReceptionistClinicMapping[]
  patients         PatientClinicMapping[]
  clinicServices   ClinicServicePrice[]

  @@map("clinics")
}

// ============================================
// DOCTOR MANAGEMENT
// ============================================

model Doctor {
  id               String    @id @default(cuid())
  userId           String    @unique
  specialties      Json?     // Array of specialty IDs
  consultationFee  Decimal?  @db.Decimal(10, 2)
  about            String?   @db.Text
  signature        Int?      // Media ID for digital signature
  status           Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinics       DoctorClinicMapping[]
  services      DoctorServiceMapping[]
  specialtiesRef Specialty[]
  appointments  Appointment[]
  encounters   Encounter[]
  prescriptions Prescription[]
  schedules    DoctorSession[]
  patientAddedPatients Patient[] @relation("PatientAddedBy")

  @@map("doctors")
}

model Specialty {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      Int      @default(1)
  createdAt   DateTime @default(now())

  doctors Doctor[]

  @@map("specialties")
}

model DoctorClinicMapping {
  id            String   @id @default(cuid())
  doctorId      String
  clinicId      String
  createdAt     DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([doctorId, clinicId])
  @@map("doctor_clinic_mappings")
}

model DoctorSession {
  id            String   @id @default(cuid())
  doctorId      String
  clinicId      String
  dayOfWeek     Int      // 0-6 (Sunday-Saturday)
  startTime     String   // HH:mm format
  endTime       String   // HH:mm format
  slotDuration  Int      @default(30) // in minutes
  status        Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_sessions")
}

// ============================================
// PATIENT MANAGEMENT
// ============================================

model Patient {
  id               String    @id @default(cuid())
  userId           String    @unique
  patientUniqueId  String?   @unique
  bloodGroup       String?
  emergencyContact  String?
  emergencyPhone    String?
  status           Int       @default(1)
  registeredAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinics       PatientClinicMapping[]
  addedBy       Doctor?                    @relation("PatientAddedBy", fields: [addedById], references: [id])
  addedById     String?
  appointments  Appointment[]
  encounters    Encounter[]
  medicalHistory MedicalHistory[]
  prescriptions Prescription[]
  medicalProblems MedicalProblem[]

  @@map("patients")
}

model PatientClinicMapping {
  id         String   @id @default(cuid())
  patientId  String
  clinicId   String
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([patientId, clinicId])
  @@map("patient_clinic_mappings")
}

model MedicalHistory {
  id           String   @id @default(cuid())
  patientId    String
  doctorId     String?
  title        String
  description String?  @db.Text
  moduleType   String?
  moduleId     String?
  createdAt    DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("medical_history")
}

model MedicalProblem {
  id           String    @id @default(cuid())
  patientId    String
  problemName  String
  diagnosis   String?   @db.Text
  severity     String?
  status       String?
  diagnosedAt  DateTime?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("medical_problems")
}

// ============================================
// SERVICE CATALOG
// ============================================

model Service {
  id          String    @id @default(cuid())
  clinicId    String?
  type        String?
  name        String
  description String?   @db.Text
  price       Decimal   @db.Decimal(10, 2)
  duration    Int       @default(30) // in minutes
  isPrivate   Boolean   @default(false)
  status      Int       @default(1)
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clinic       Clinic?                @relation(fields: [clinicId], references: [id])
  doctors      DoctorServiceMapping[]
  appointments AppointmentServiceMapping[]
  billItems    BillItem[]

  @@map("services")
}

model ClinicServicePrice {
  id         String   @id @default(cuid())
  clinicId   String
  serviceId  String
  price      Decimal  @db.Decimal(10, 2)
  status     Int      @default(1)

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([clinicId, serviceId])
  @@map("clinic_service_prices")
}

model DoctorServiceMapping {
  id            String   @id @default(cuid())
  doctorId      String
  serviceId     String
  price         Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([doctorId, serviceId])
  @@map("doctor_service_mappings")
}

// ============================================
// APPOINTMENT SYSTEM
// ============================================

enum AppointmentStatus {
  CANCELLED  // 0
  BOOKED     // 1
  PENDING    // 2
  CHECK_OUT  // 3
  CHECK_IN   // 4
}

enum VisitType {
  IN_PERSON
  TELEMED
}

model Appointment {
  id                    String            @id @default(cuid())
  clinicId              String
  doctorId              String
  patientId             String
  appointmentStartDate  DateTime          @db.Date
  appointmentStartTime String            @db.Time
  appointmentEndDate    DateTime?         @db.Date
  appointmentEndTime   String?           @db.Time
  appointmentStartUtc   DateTime          @db.DateTime
  appointmentEndUtc     DateTime?
  appointmentTimezone   String            @default("UTC")
  visitType             VisitType         @default(IN_PERSON)
  description           String?           @db.Text
  status                AppointmentStatus @default(PENDING)
  appointmentReport    String?           @db.Text
  createdAt             DateTime          @default(now())
  createdAtUtc          DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  // Relations
  clinic       Clinic?                    @relation(fields: [clinicId], references: [id])
  doctor       Doctor?                    @relation(fields: [doctorId], references: [id])
  patient      Patient?                   @relation(fields: [patientId], references: [id])
  services     AppointmentServiceMapping[]
  encounter    Encounter?
  reminders    AppointmentReminder[]
  paymentMappings PaymentAppointmentMapping[]

  @@index([clinicId])
  @@index([doctorId])
  @@index([patientId])
  @@index([appointmentStartDate])
  @@index([status])
  @@map("appointments")
}

model AppointmentServiceMapping {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  price         Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
  @@map("appointment_service_mappings")
}

model AppointmentReminder {
  id            String   @id @default(cuid())
  appointmentId String
  reminderType  String
  scheduledFor DateTime
  sentAt        DateTime?
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_reminders")
}

// ============================================
// ENCOUNTER MANAGEMENT
// ============================================

model Encounter {
  id            String   @id @default(cuid())
  appointmentId String?  @unique
  patientId     String
  doctorId      String
  clinicId      String
  encounterDate DateTime @default(now())
  clinicalNotes String?  @db.Text
  status        String   @default("open")
  medicalReport String?  @db.Text
  templateId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment  Appointment?  @relation(fields: [appointmentId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  prescriptions Prescription[]
  bills         Bill[]
  vitalSigns    VitalSign[]

  @@map("patient_encounters")
}

// ============================================
// PRESCRIPTION MANAGEMENT
// ============================================

model Prescription {
  id            String   @id @default(cuid())
  encounterId   String
  patientId     String
  doctorId      String
  medicineName  String
  dosage        String
  frequency     String
  duration      String
  instructions  String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id])

  @@map("prescriptions")
}

model VitalSign {
  id           String   @id @default(cuid())
  encounterId  String
  vitalType    String
  vitalValue   String
  vitalUnit    String?
  recordedAt   DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@map("vital_signs")
}

model EncounterTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  content     Json
  clinicId    String?
  status      Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("encounter_templates")
}

// ============================================
// SCHEDULING
// ============================================

model ClinicSchedule {
  id        String   @id @default(cuid())
  clinicId  String
  dayOfWeek Int
  startTime String   @db.VarChar(10)
  endTime   String   @db.VarChar(10)
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_schedules")
}

model ClinicSession {
  id           String   @id @default(cuid())
  clinicId     String
  doctorId     String?
  sessionDate  DateTime @db.Date
  startTime    String   @db.Time
  endTime      String   @db.Time
  slotDuration Int      @default(30)
  isAvailable  Int      @default(1)
  createdAt    DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([sessionDate])
  @@map("clinic_sessions")
}

model Holiday {
  id         String   @id @default(cuid())
  moduleType  String
  moduleId   String
  title      String
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  isAllDay   Boolean  @default(true)
  startTime  String?  @db.Time
  endTime    String?  @db.Time
  createdAt  DateTime @default(now())

  clinic Clinic? @relation(fields: [moduleId], references: [id], map: "holiday_clinic_fk")

  @@index([moduleType, moduleId])
  @@map("holiday_list")
}

// ============================================
// BILLING & PAYMENTS
// ============================================

model Bill {
  id            String   @id @default(cuid())
  encounterId   String?
  clinicId      String
  patientId    String
  totalAmount  Decimal  @db.Decimal(10, 2)
  discount     Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount    Decimal  @default(0) @db.Decimal(10, 2)
  actualAmount Decimal  @db.Decimal(10, 2)
  paymentStatus String  @default("pending")
  paymentMethod String?
  notes         String? @db.Text
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  encounter Encounter? @relation(fields: [encounterId], references: [id])
  clinic   Clinic     @relation(fields: [clinicId], references: [id])
  items    BillItem[]

  @@map("bills")
}

model BillItem {
  id        String   @id @default(cuid())
  billId    String
  serviceId String?
  itemName  String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@map("bill_items")
}

model Payment {
  id            String   @id @default(cuid())
  billId        String
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String
  transactionId String?
  status        String   @default("completed")
  metadata      Json?
  createdAt     DateTime @default(now())

  @@map("payments")
}

model PaymentAppointmentMapping {
  id            String   @id @default(cuid())
  paymentId     String
  appointmentId String
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  payment     Payment      @relation(fields: [paymentId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@map("payment_appointment_mappings")
}

model Tax {
  id        String   @id @default(cuid())
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  status    Int      @default(1)
  clinicId  String?
  createdAt DateTime @default(now())

  @@map("taxes")
}

// ============================================
// CUSTOM FIELDS
// ============================================

model CustomField {
  id          String   @id @default(cuid())
  moduleType  String
  fieldLabel  String
  fieldType   String
  options     Json?
  placeholder String?
  isRequired  Boolean  @default(false)
  status      Int      @default(1)
  clinicId    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  fieldData CustomFieldData[]

  @@map("custom_fields")
}

model CustomFieldData {
  id          String   @id @default(cuid())
  moduleType  String
  moduleId    String
  fieldId     String
  fieldValue  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  field CustomField @relation(fields: [fieldId], references: [id])

  @@unique([moduleType, moduleId, fieldId])
  @@map("custom_field_data")
}

// ============================================
// SETTINGS & CONFIGURATION
// ============================================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  type      String   @default("default")
  ownerId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subject   String
  body      String   @db.Text
  variables Json?
  type      String   @default("email")
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ============================================
// RECEPTIONIST
// ============================================

model Receptionist {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinics ReceptionistClinicMapping[]

  @@map("receptionists")
}

model ReceptionistClinicMapping {
  id             String   @id @default(cuid())
  receptionistId String
  clinicId       String
  createdAt      DateTime @default(now())

  receptionist Receptionist @relation(fields: [receptionistId], references: [id], onDelete: Cascade)
  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([receptionistId, clinicId])
  @@map("receptionist_clinic_mappings")
}

// ============================================
// STATIC DATA
// ============================================

model StaticData {
  id        String   @id @default(cuid())
  type      String
  label     String
  value     String
  extra     Json?
  sortOrder Int      @default(0)
  status    Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([type, value])
  @@map("static_data")
}

// ============================================
// MEDIA / FILES
// ============================================

model Media {
  id           String   @id @default(cuid())
  filename     String
  fileType     String
  fileSize     Int
  url          String
  thumbnailUrl String?
  alt          String?
  userId       String?
  createdAt    DateTime @default(now())

  @@map("media")
}

// ============================================
// LOGGING — user activity + errors
// ============================================
// Source of truth: docs/architecture/logging.md
// Constitution §Logging & Monitoring mandates database-backed structured
// logging. This is the single table for all log records; the `level` and
// `category` fields determine retention (see logging.md).
//
// Conventions:
//   - ACTIVITY entries: every meaningful user action (login, booking, edit).
//   - ERROR entries: unhandled exceptions, 5xx responses, integration failures.
//   - SYSTEM entries: background jobs, cron, scheduled tasks.
//   - AUTH events (login success/failure, password change) ALSO go here with
//     category=ACTIVITY and level=INFO/WARN. The auth-foundation spec's
//     AuditLog is a query view over this table filtered by action prefix.
//
// Access: SUPER_ADMIN read via GET /api/v1/admin/logs (paginated).
// Retention (per constitution):
//   DEBUG, TRACE  → 7 days
//   INFO, WARN    → 30 days
//   ERROR         → 30 days
//   AUDIT         → 90 days
//   PERF          → 7 days (aggregated; deferred)
// A scheduled job (C8) purges entries older than the retention window.

enum LogLevel {
  DEBUG
  TRACE
  INFO
  WARN
  ERROR
  AUDIT
  PERF
}

enum LogCategory {
  ACTIVITY // user-facing actions
  ERROR    // unhandled exceptions, integration failures
  SYSTEM   // background jobs, scheduled tasks, server lifecycle
}

model LogEntry {
  id         String      @id @default(cuid())
  level      LogLevel    @default(INFO)
  category   LogCategory @default(ACTIVITY)
  message    String      @db.Text
  userId     String?     // null for anonymous / system events
  action     String?     // dotted path: "user.login", "session.book", "client.create"
  resource   String?     // entity affected: "session", "client", "bill"
  resourceId String?
  ip         String?
  userAgent  String?     @db.Text
  requestId  String?     // correlate across handlers in one request
  path       String?     // request path (e.g. "/api/v1/sessions")
  method     String?     // HTTP method
  statusCode Int?        // response status (for API-request entries)
  errorStack String?     @db.Text // populated when an Error object is passed
  metadata   Json?       // free-form context (sanitized request body, before/after values, etc.)
  occurredAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([level, occurredAt])
  @@index([category, occurredAt])
  @@index([userId, occurredAt])
  @@index([action, occurredAt])
  @@index([requestId])
  @@index([occurredAt])
  @@map("log_entries")
}