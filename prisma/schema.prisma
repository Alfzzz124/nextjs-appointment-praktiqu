// ============================================================
// PraktiQU - Clinic Management System
// ============================================================
// Database Schema based on KiviCare WordPress Plugin
//
// This schema mirrors the KiviCare database structure
// for the Next.js recreation
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================
// PraktiQU and WordPress share a single MySQL instance (sibling model).
// WordPress is the SOLE source of truth for credentials. There is NO password
// column on the PraktiQU User — passwords live in wp_users.user_pass (PHPASS).
// PraktiQU verifies passwords by calling the praktiqu-auth WP plugin's REST
// endpoint: POST /wp-json/praktiqu/v1/authenticate
//
// Identity + credential staleness is addressed via signed webhooks emitted by
// the praktiqu-auth plugin (password.changed, user.deactivated, etc.).
// See: src/lib/auth/role-mapping.ts and docs/architecture/role-taxonomy.md.

enum UserRole {
  SUPER_ADMIN     // WP role: "administrator" (core WP)
  CLINIC_ADMIN    // WP role: "kiviCare_clinic_admin"
  PROFESSIONAL    // WP role: "kiviCare_doctor"
  RECEPTIONIST    // WP role: "kiviCare_receptionist"
  CLIENT          // WP role: "kiviCare_patient"
}

enum AuditEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  TOKEN_REFRESH
  TOKEN_REVOKE
  PASSWORD_CHANGE
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_COMPLETE
  ROLE_CHANGE
  REGISTER
  WEBHOOK_RECEIVED
  EMAIL_DELIVERY_FAILED
  OAUTH_LINK
}

enum RefreshTokenStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum WebhookEventName {
  PASSWORD_CHANGED
  USER_DEACTIVATED
  USER_REACTIVATED
  USER_DELETED
  USER_ROLE_CHANGED
  LOGIN_FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  firstName     String
  lastName      String
  displayName   String
  role          UserRole  @default(CLIENT)
  // NOTE: No password column — WP owns credentials. See block comment above.
  wpRole        String?   // raw WordPress role slug (e.g. "kiviCare_doctor"); null if provisioned outside WP
  wpUserId      BigInt?   @unique // WordPress user ID (wp_users.ID) for cross-system lookups
  status        Int       @default(1) // 0 = inactive, 1 = active
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  clinicAdmin   Clinic?               @relation("ClinicAdmin")
  doctor        Doctor?
  receptionist  Receptionist?
  patient       Patient?
  sessions      AuthSession[]
  logEntries    LogEntry[]
  consentSignatures ConsentSignature[]
  refreshTokens RefreshToken[]
  passwordResets PasswordResetToken[]
  googleIdentity GoogleIdentity?

  // Audit (actor = person performing action; target = affected user)
  auditsAsActor  AuditLog[] @relation("ActorAudits")
  auditsAsTarget AuditLog[] @relation("TargetAudits")

  // Role assignments
  doctorClinics       DoctorClinicMapping[]
  receptionistClinics ReceptionistClinicMapping[]
  patientClinics      PatientClinicMapping[]
  professional        Professional?                @relation("UserProfessional")

  // Meta data
  basicData     Json?    // mobile_number, dob, gender, blood_group, address, etc.
  timezone      String?

  @@index([wpUserId])
  @@index([wpRole])
  @@map("users")
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================================
// REFRESH TOKENS — JWT refresh-token tracking
// ============================================
// Stores SHA-256 hashes of refresh tokens; the raw token is never persisted.
// Family ID groups all tokens in a single lineage so a replay attack can
// revoke the entire family per FR-015.

model RefreshToken {
  id            String             @id @default(cuid())
  userId        String
  tokenHash     String             @unique // SHA-256 of raw token
  familyId      String             // groups tokens in the same login lineage
  status        RefreshTokenStatus @default(ACTIVE)
  userAgent     String?            @db.Text
  ipAddress     String?
  issuedAt      DateTime           @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  replacedById  String?            @unique
  parentId      String?            @unique // previous token in the rotation chain

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy   RefreshToken? @relation("RotationChild", fields: [replacedById], references: [id])
  parent       RefreshToken? @relation("RotationParent", fields: [parentId], references: [id])
  replacedTokens RefreshToken[] @relation("RotationParent")
  childTokens  RefreshToken[] @relation("RotationChild")

  @@index([userId])
  @@index([familyId])
  @@index([status])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// PASSWORD RESET TOKENS
// ============================================

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique // SHA-256 of raw token
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
  ipAddress  String?
  userAgent  String?   @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ============================================
// OAUTH LINKAGE — Google account → PraktiQU user
// ============================================

model GoogleIdentity {
  id           String   @id @default(cuid())
  userId       String
  googleSub    String   @unique // Google subject identifier
  email        String
  linkedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
  @@map("google_identities")
}

// ============================================
// AUDIT LOG — security events (FR-010/011/012/022)
// ============================================

model AuditLog {
  id          String         @id @default(cuid())
  eventType   AuditEventType
  actorId     String?
  targetId    String?
  ip          String?
  userAgent   String?        @db.Text
  metadata    Json?
  occurredAt  DateTime       @default(now())

  actor  User? @relation("ActorAudits", fields: [actorId], references: [id], onDelete: SetNull)
  target User? @relation("TargetAudits", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([eventType, occurredAt])
  @@index([actorId, occurredAt])
  @@index([targetId, occurredAt])
  @@index([occurredAt])
  @@map("audit_logs")
}

// ============================================
// WORDPRESS WEBHOOK EVENTS — idempotency + replay protection
// ============================================

model WordpressWebhookEvent {
  id            String              @id @default(cuid())
  eventId       String              // id supplied by the WP plugin (unique per event)
  eventName     WebhookEventName
  wpUserId      BigInt?
  payload       Json
  signature     String?
  receivedAt    DateTime            @default(now())
  processedAt   DateTime?
  status        WebhookEventStatus  @default(RECEIVED)
  failureReason String?             @db.Text

  @@unique([eventId])
  @@index([eventName, receivedAt])
  @@index([wpUserId])
  @@index([status])
  @@map("wordpress_webhook_events")
}

// ============================================
// CLINIC MANAGEMENT
// ============================================

model Clinic {
  id                 String   @id @default(cuid())
  name               String
  email              String?
  telephoneNo        String?
  specialties        Json?    // Array of specialty IDs/names
  address            String?
  city               String?
  state              String?
  country            String?
  postalCode         String?
  countryCode        String?
  countryCallingCode String?
  status             Int      @default(0) // 0 = inactive, 1 = active
  clinicAdminId      String?  @unique
  clinicLogo         Int?
  profileImage       Int?
  extra              Json?    // currency settings, custom config
  // Invoice numbering (011-billing)
  code               String?  @unique // 2-4 char alphanumeric slug, e.g. "JKT", "BDG"
  billSequence       Int      @default(0) // next sequence number
  billSequenceYear   Int?     // year the sequence applies to (for year rollover)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  clinicAdmin      User?                      @relation("ClinicAdmin", fields: [clinicAdminId], references: [id])
  appointments    Appointment[]
  encounters       Encounter[]
  bills            Bill[]
  clinicSessions   ClinicSession[]
  clinicSchedules  ClinicSchedule[]
  holidays         Holiday[]
  services         Service[]
  doctors          DoctorClinicMapping[]
  receptionists    ReceptionistClinicMapping[]
  patients         PatientClinicMapping[]
  clinicServices   ClinicServicePrice[]
  professionals    Professional[]             @relation("ClinicProfessionals")

  @@map("clinics")
}

// ============================================
// DOCTOR MANAGEMENT
// ============================================

model Doctor {
  id               String    @id @default(cuid())
  userId           String    @unique
  specialties      Json?     // Array of specialty IDs
  consultationFee  Decimal?  @db.Decimal(10, 2)
  about            String?   @db.Text
  signature        Int?      // Media ID for digital signature
  status           Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinics       DoctorClinicMapping[]
  services      DoctorServiceMapping[]
  specialtiesRef Specialty[]
  appointments  Appointment[]
  sessions      Session[]                @relation("SessionProfessional")
  encounters   Encounter[]
  prescriptions Prescription[]
  schedules    DoctorSession[]
  patientAddedPatients Patient[] @relation("PatientAddedBy")

  @@map("doctors")
}

model Specialty {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      Int      @default(1)
  createdAt   DateTime @default(now())

  doctors Doctor[]

  @@map("specialties")
}

model DoctorClinicMapping {
  id            String   @id @default(cuid())
  doctorId      String
  clinicId      String
  createdAt     DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([doctorId, clinicId])
  @@map("doctor_clinic_mappings")
}

model DoctorSession {
  id            String   @id @default(cuid())
  doctorId      String
  clinicId      String
  dayOfWeek     Int      // 0-6 (Sunday-Saturday)
  startTime     String   // HH:mm format
  endTime       String   // HH:mm format
  slotDuration  Int      @default(30) // in minutes
  status        Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_sessions")
}

// ============================================
// CLIENT MANAGEMENT (Feature 004)
// ============================================
// A Client is the practice's end-user record. Distinct from the legacy
// `Patient` model (which mirrors KiviCare's clinical record). One Client
// belongs to exactly one Practice in v1, links one-to-one to a WordPress
// user, and has a human-readable `CLT-YYYY-NNNNN` unique ID per practice.

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ClientStatus {
  ACTIVE    // can book
  INACTIVE  // paused / departed
  ARCHIVED  // soft-deleted (history preserved)
}

model Client {
  id               String       @id @default(cuid())
  userId           String       @unique          // WordPress user link
  practiceId       String                        // FK to Clinic
  uniqueClientId   String                        // e.g. CLT-2026-00001
  fullName         String       @db.VarChar(100)
  email            String       @db.VarChar(255)
  mobileNumber     String       @db.VarChar(20)
  dateOfBirth      DateTime
  gender           Gender
  address          String?      @db.Text
  emergencyContact String?      @db.VarChar(100)
  notes            String?      @db.Text
  status           ClientStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([practiceId, uniqueClientId])
  @@unique([practiceId, email])
  @@index([practiceId, status])
  @@index([fullName])
  @@index([mobileNumber])
  @@map("clients")
}

// ============================================
// PATIENT MANAGEMENT (legacy KiviCare clinical record)
// ============================================

model Patient {
  id               String    @id @default(cuid())
  userId           String    @unique
  patientUniqueId  String?   @unique
  bloodGroup       String?
  emergencyContact  String?
  emergencyPhone    String?
  status           Int       @default(1)
  registeredAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinics       PatientClinicMapping[]
  addedBy       Doctor?                    @relation("PatientAddedBy", fields: [addedById], references: [id])
  addedById     String?
  appointments  Appointment[]
  sessions      Session[]                  @relation("SessionClient")
  encounters    Encounter[]
  medicalHistory MedicalHistory[]
  prescriptions Prescription[]
  medicalProblems MedicalProblem[]

  @@map("patients")
}

model PatientClinicMapping {
  id         String   @id @default(cuid())
  patientId  String
  clinicId   String
  createdAt  DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([patientId, clinicId])
  @@map("patient_clinic_mappings")
}

model MedicalHistory {
  id           String   @id @default(cuid())
  patientId    String
  doctorId     String?
  title        String
  description String?  @db.Text
  moduleType   String?
  moduleId     String?
  createdAt    DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("medical_history")
}

model MedicalProblem {
  id           String    @id @default(cuid())
  patientId    String
  problemName  String
  diagnosis   String?   @db.Text
  severity     String?
  status       String?
  diagnosedAt  DateTime?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("medical_problems")
}

// ============================================
// SERVICE CATALOG
// ============================================
// Service catalog management (spec 003-service-mgmt).
//   - ServiceType/ServiceStatus enums drive UI/API strict types
//   - durationMinutes is the primary input to slot generation (002 FR-007)
//   - name uniqueness is enforced per clinic (FR-002, SC-006)
//   - durationMinutes restricted to {30, 60, 90, 120, 150, 180} (FR-003)
//   - price is a non-negative integer in the smallest currency unit (FR-014)
//   - physical deletion requires INACTIVE + zero assignments + zero bookings (FR-009)

enum ServiceType {
  KONSELING
  ASESMEN
  WORKSHOP
}

enum ServiceStatus {
  ACTIVE
  INACTIVE
}

model Service {
  id              String        @id @default(cuid())
  clinicId        String?
  type            String?
  name            String
  description     String?       @db.Text
  price           Decimal       @db.Decimal(10, 2)
  duration        Int           @default(30) // legacy free-form minutes
  durationMinutes Int           @default(60) // canonical for spec 003 — 30/60/90/120/150/180
  serviceType     ServiceType   @default(KONSELING)
  status          ServiceStatus @default(ACTIVE)
  isPrivate       Boolean       @default(false)
  legacyStatus    Int           @default(1) // mirrors `status` for legacy int-based callers
  imageUrl        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clinic       Clinic?                @relation(fields: [clinicId], references: [id])
  doctors      DoctorServiceMapping[]
  appointments AppointmentServiceMapping[]
  sessions     Session[]                @relation("SessionService")
  billItems    BillItem[]
  clinicServices ClinicServicePrice[]

  @@unique([clinicId, name])
  @@index([clinicId, status])
  @@index([serviceType])
  @@map("services")
}

// ============================================
// SESSION MANAGEMENT (Feature 005)
// ============================================
// Session: a booked session between a client and professional.
// Status lifecycle: PENDING -> BOOKED -> CHECK_IN -> CHECK_OUT -> COMPLETED.
// Terminal: REJECTED, CANCELLED.
// See: specs/005-session-mgmt/data-model.md

enum SessionStatus {
  PENDING     // awaiting professional approval (client-initiated booking)
  BOOKED      // confirmed (professional approved or staff booked directly)
  CHECK_IN    // client has arrived
  CHECK_OUT   // session ended
  COMPLETED   // auto-closed after 24h
  REJECTED    // professional rejected
  CANCELLED   // cancelled before start
}

model Session {
  id               String        @id @default(cuid())
  clientId         String
  professionalId   String
  serviceId        String
  practiceId       String
  slotDate         DateTime      @db.Date
  startTime        DateTime
  endTime          DateTime
  status           SessionStatus @default(PENDING)
  rejectionReason  String?       @db.Text
  cancellationReason String?     @db.Text
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  createdBy        String        // userId of creator (client or receptionist)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  client         Patient    @relation("SessionClient", fields: [clientId], references: [id])
  professional   Doctor     @relation("SessionProfessional", fields: [professionalId], references: [id])
  service        Service    @relation("SessionService", fields: [serviceId], references: [id])

  @@index([professionalId, slotDate, status])
  @@index([clientId, slotDate])
  @@index([practiceId, slotDate])
  @@index([status])
  @@index([slotDate, status])
  @@index([status, checkedOutAt])
  @@map("sessions_booking")
}

model ClinicServicePrice {
  id         String   @id @default(cuid())
  clinicId   String
  serviceId  String
  price      Decimal  @db.Decimal(10, 2)
  status     Int      @default(1)

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([clinicId, serviceId])
  @@map("clinic_service_prices")
}

model DoctorServiceMapping {
  id            String   @id @default(cuid())
  doctorId      String
  serviceId     String
  price         Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([doctorId, serviceId])
  @@map("doctor_service_mappings")
}

// ============================================
// APPOINTMENT SYSTEM
// ============================================

enum AppointmentStatus {
  CANCELLED  // 0
  BOOKED     // 1
  PENDING    // 2
  CHECK_OUT  // 3
  CHECK_IN   // 4
}

enum VisitType {
  IN_PERSON
  TELEMED
}

model Appointment {
  id                    String            @id @default(cuid())
  clinicId              String
  doctorId              String
  patientId             String
  appointmentStartDate  DateTime          @db.Date
  appointmentStartTime DateTime          @db.Time
  appointmentEndDate    DateTime?         @db.Date
  appointmentEndTime   DateTime?         @db.Time
  appointmentStartUtc   DateTime          @db.DateTime
  appointmentEndUtc     DateTime?
  appointmentTimezone   String            @default("UTC")
  visitType             VisitType         @default(IN_PERSON)
  description           String?           @db.Text
  status                AppointmentStatus @default(PENDING)
  appointmentReport    String?           @db.Text
  createdAt             DateTime          @default(now())
  createdAtUtc          DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  // Relations
  clinic       Clinic?                    @relation(fields: [clinicId], references: [id])
  doctor       Doctor?                    @relation(fields: [doctorId], references: [id])
  patient      Patient?                   @relation(fields: [patientId], references: [id])
  services     AppointmentServiceMapping[]
  encounter    Encounter?
  reminders    AppointmentReminder[]
  paymentMappings PaymentAppointmentMapping[]

  @@index([clinicId])
  @@index([doctorId])
  @@index([patientId])
  @@index([appointmentStartDate])
  @@index([status])
  @@map("appointments")
}

model AppointmentServiceMapping {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  price         Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@unique([appointmentId, serviceId])
  @@map("appointment_service_mappings")
}

model AppointmentReminder {
  id            String   @id @default(cuid())
  appointmentId String
  reminderType  String
  scheduledFor DateTime
  sentAt        DateTime?
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("appointment_reminders")
}

// ============================================
// ENCOUNTER MANAGEMENT
// ============================================

model Encounter {
  id            String   @id @default(cuid())
  appointmentId String?  @unique
  patientId     String
  doctorId      String
  clinicId      String
  encounterDate DateTime @default(now())
  clinicalNotes String?  @db.Text
  status        String   @default("open")
  medicalReport String?  @db.Text
  templateId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment  Appointment?  @relation(fields: [appointmentId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  clinic       Clinic       @relation(fields: [clinicId], references: [id])
  prescriptions Prescription[]
  bills         Bill[]
  vitalSigns    VitalSign[]

  @@map("patient_encounters")
}

// ============================================
// PRESCRIPTION MANAGEMENT
// ============================================

model Prescription {
  id            String   @id @default(cuid())
  encounterId   String
  patientId     String
  doctorId      String
  medicineName  String
  dosage        String
  frequency     String
  duration      String
  instructions  String?  @db.Text
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  patient   Patient   @relation(fields: [patientId], references: [id])
  doctor    Doctor    @relation(fields: [doctorId], references: [id])

  @@map("prescriptions")
}

model VitalSign {
  id           String   @id @default(cuid())
  encounterId  String
  vitalType    String
  vitalValue   String
  vitalUnit    String?
  recordedAt   DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@map("vital_signs")
}

model EncounterTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  content     Json
  clinicId    String?
  status      Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("encounter_templates")
}

// ============================================
// SCHEDULING
// ============================================

model ClinicSchedule {
  id        String   @id @default(cuid())
  clinicId  String
  dayOfWeek Int
  startTime String   @db.VarChar(10)
  endTime   String   @db.VarChar(10)
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_schedules")
}

model ClinicSession {
  id           String   @id @default(cuid())
  clinicId     String
  doctorId     String?
  sessionDate  DateTime @db.Date
  startTime    DateTime @db.Time
  endTime      DateTime @db.Time
  slotDuration Int      @default(30)
  isAvailable  Int      @default(1)
  createdAt    DateTime @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([sessionDate])
  @@map("clinic_sessions")
}

model Holiday {
  id         String   @id @default(cuid())
  moduleType  String
  moduleId   String
  title      String
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  isAllDay   Boolean  @default(true)
  startTime  DateTime? @db.Time
  endTime    DateTime? @db.Time
  createdAt  DateTime @default(now())

  clinic Clinic? @relation(fields: [moduleId], references: [id], map: "holiday_clinic_fk")

  @@index([moduleType, moduleId])
  @@map("holiday_list")
}

// ============================================
// BILLING & PAYMENTS
// ============================================

model Bill {
  id            String   @id @default(cuid())
  encounterId   String?
  clinicId      String
  patientId    String
  totalAmount  Decimal  @db.Decimal(10, 2)
  discount     Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount    Decimal  @default(0) @db.Decimal(10, 2)
  actualAmount Decimal  @db.Decimal(10, 2)
  paymentStatus String  @default("pending")
  paymentMethod String?
  notes         String? @db.Text
  dueDate       DateTime?
  paidAt        DateTime?
  // 011-billing additions
  billNumber    String?  @unique // INV-{clinicCode}-{YYYY}-{NNNNN}
  status        String   @default("DRAFT") // DRAFT|ISSUED|PAID|PARTIAL|VOID|REFUNDED
  paidAmount    Decimal  @default(0) @db.Decimal(10, 2)
  balanceDue    Decimal  @default(0) @db.Decimal(10, 2)
  voidedAt      DateTime?
  voidedBy      String?
  voidReason    String?  @db.Text
  disputedAt    DateTime?
  disputeReason String?  @db.Text
  professionalId String?
  createdBy     String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  encounter     Encounter?    @relation(fields: [encounterId], references: [id])
  clinic        Clinic        @relation(fields: [clinicId], references: [id])
  items         BillItem[]
  payments      Payment[]

  @@index([clinicId, status])
  @@index([patientId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("bills")
}

model BillItem {
  id          String   @id @default(cuid())
  billId      String
  serviceId   String?
  itemName    String
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(1)
  // 011-billing additions
  type        String   @default("SERVICE") // SERVICE|DISCOUNT|OTHER
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  unitPrice   Decimal? @db.Decimal(10, 2)
  lineTotal   Decimal? @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  bill    Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([billId])
  @@map("bill_items")
}

model Payment {
  id                    String   @id @default(cuid())
  billId                String
  amount                Decimal  @db.Decimal(10, 2)
  paymentMethod         String
  transactionId         String?
  status                String   @default("completed")
  // 011-billing additions
  stripePaymentIntentId String?  @unique
  refundedPaymentId     String?
  notes                 String?  @db.Text
  paidAt                DateTime?
  createdBy             String?
  metadata              Json?
  createdAt             DateTime @default(now())

  bill               Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  refundedPayment    Payment? @relation("RefundLink", fields: [refundedPaymentId], references: [id])
  refunds            Payment[] @relation("RefundLink")
  appointmentMappings PaymentAppointmentMapping[]

  @@index([billId])
  @@index([status])
  @@map("payments")
}

model PaymentAppointmentMapping {
  id            String   @id @default(cuid())
  paymentId     String
  appointmentId String
  amount        Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())

  payment     Payment      @relation(fields: [paymentId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@map("payment_appointment_mappings")
}

model Tax {
  id        String   @id @default(cuid())
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  status    Int      @default(1)
  clinicId  String?
  createdAt DateTime @default(now())

  @@map("taxes")
}

