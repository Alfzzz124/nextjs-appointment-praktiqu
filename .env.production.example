# ===========================================
# PraktiQU Production Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# ===========================================

# ===========================================
# DATABASE (Prisma - MySQL)
# ===========================================
DATABASE_URL="mysql://user:password@host:3306/praktiqu"

# ===========================================
# WORDPRESS INTEGRATION
# ===========================================
WORDPRESS_DATABASE_URL="mysql://user:password@host:3306/wordpress"
WORDPRESS_TABLE_PREFIX="wp_"
WORDPRESS_URL="https://your-wordpress-site.com"
WORDPRESS_AUTH_SYNC="true"

# Service-to-service auth header for the custom WP REST endpoint
WORDPRESS_SERVICE_TOKEN="generate-secure-token-here"

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-production-auth-secret-here"

# Public application URL (use your actual domain)
AUTH_URL="https://your-domain.com"
NEXTAUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"

# ===========================================
# APPLICATION SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="PraktiQU"
DEFAULT_TIMEZONE="Asia/Jakarta"
DEFAULT_PAGE_SIZE="20"
MAX_PAGE_SIZE="100"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL="INFO"

# ===========================================
# EMAIL (Production)
# ===========================================
EMAIL_FROM="noreply@your-domain.com"
SMTP_HOST="smtp.your-email-provider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@your-domain.com"
SMTP_PASS="your-email-password"

# ===========================================
# DEPLOYMENT
# ===========================================
NODE_ENV="production"
PORT=3000
HOST="0.0.0.0"